{
    "$schema": "https://railway.app/railway.schema.json",
    "services": {
        "backend": {
            "source": {
                "root": "backend"
            },
            "config": {
                "dockerfile": "backend/Dockerfile",
                "healthcheckPath": "/health",
                "healthcheckTimeout": 5
            }
        },
        "frontend": {
            "source": {
                "root": "frontend"
            },
            "config": {
                "dockerfile": "frontend/Dockerfile",
                "healthcheckPath": "/",
                "healthcheckTimeout": 10
            }
        }
    }
}